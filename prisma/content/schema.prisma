generator client {
  provider      = "prisma-client-js"
  output        = "../../node_modules/@prisma/client-content"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_CONTENT_URL")
}

model Topic {
  id             String              @id @default(cuid())
  name           String              @unique // Normalized name (lowercase)
  aliases        Alias[]
  articles       WikiArticle[]
  shipLogs       ShipLog[]
  tags           Tag[]
  expeditionLogs ExpeditionShipLog[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model Tag {
  id     String  @id @default(cuid())
  name   String  @unique
  topics Topic[]
}


model Alias {
  id        String   @id @default(cuid())
  name      String   @unique
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id])
  createdAt DateTime @default(now())
}


model User {
  id                      String               @id
  shipLogs                ShipLog[]
  chatHistory             ChatHistory[]
  commsMessages           CommsMessage[]
  following               Follow[]             @relation("UserFollowing")
  followers               Follow[]             @relation("UserFollowers")
  achievements            Achievement[]
  ownedExpeditions        Expedition[]         @relation("ExpeditionOwner")
  expeditionMemberships   ExpeditionMember[]
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
}

model ChatHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // 'user' | 'assistant'
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model CommsMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  channel   String   @default("global") // For future channels (e.g. "team", "guild")
  createdAt DateTime @default(now())
}


model ShipLog {
  id           String   @id @default(cuid())
  userId       String   // Reference to Main DB User
  user         User     @relation(fields: [userId], references: [id])
  topicId      String
  topic        Topic    @relation(fields: [topicId], references: [id])
  discoveredAt DateTime @default(now())

  @@unique([userId, topicId])
}

model WikiArticle {
  id        String   @id @default(cuid())
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title     String?  // Localized Title
  content   String?  @db.Text // Optional: Can be null if only title is translated (Lazy Loading)
  language  String   @default("en")
  updatedAt DateTime @updatedAt
  
  @@unique([topicId, language])
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   // 'first_contact', 'pioneer', 'constellation_maker', 'cartographer', 'social_butterfly', 'deep_diver'
  tier       Int      @default(1) // 1=Bronze, 2=Silver, 3=Gold
  unlockedAt DateTime @default(now())

  @@unique([userId, type, tier])
}

model Expedition {
  id          String              @id @default(cuid())
  name        String
  description String?             @db.Text
  ownerId     String
  owner       User                @relation("ExpeditionOwner", fields: [ownerId], references: [id])
  status      String              @default("active") // 'active', 'completed', 'archived'
  members     ExpeditionMember[]
  sharedLogs  ExpeditionShipLog[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ExpeditionMember {
  id           String     @id @default(cuid())
  expeditionId String
  expedition   Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         String     @default("member") // 'owner', 'member'
  joinedAt     DateTime   @default(now())

  @@unique([expeditionId, userId])
}

model ExpeditionShipLog {
  id           String     @id @default(cuid())
  expeditionId String
  expedition   Expedition @relation(fields: [expeditionId], references: [id], onDelete: Cascade)
  userId       String     // The member who added it
  topicId      String
  topic        Topic      @relation(fields: [topicId], references: [id])
  discoveredAt DateTime   @default(now())

  @@unique([expeditionId, topicId])
}
